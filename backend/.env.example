PORT=4000
APP_TIMEZONE=Europe/Prague

# Při nasazení backendu jinde než frontend (např. Vercel) – povolený CORS origin
# FRONTEND_ORIGIN=https://popelnice.vercel.app

# Gmail SMTP – zadej svůj Gmail účet a App Password z myaccount.google.com/apppasswords
GMAIL_USER=tvuj.email@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

TEST_RECIPIENT_EMAIL=tvuj.email@gmail.com

# Volitelné: datum poslední aktualizace dat (svozy/poplatky), formát YYYY-MM-DD – zobrazí se v aplikaci
# DATA_LAST_UPDATED=2026-03-19
